# Copie para deploy/.env e ajuste conforme o hardware.
# cp deploy/.env.example deploy/.env

# --- API do motor ---
NARRACAO_API_PORT=8787
PROTAGONIST_ID=ryan_wireghost_voss
MAX_CONTEXT_CHARS=32000

# --- Ollama (stack laptop) ---
OLLAMA_HOST_PORT=11434
OLLAMA_MODEL_NARRATION=llama3.1:8b
OLLAMA_MODEL_CLASSIFIER=phi3:mini

# Modelos alternativos (comentar/descomentar):
# OLLAMA_MODEL_NARRATION=mistral:7b
# OLLAMA_MODEL_NARRATION=qwen2.5:7b

# --- GPU (Docker Desktop + NVIDIA Container Toolkit no Windows/Linux) ---
NVIDIA_GPU_COUNT=1

# --- Roteamento (futuro ProviderRouter) ---
LLM_ROUTING_POLICY=local_preferred
CLOUD_FALLBACK_ENABLED=false

# --- Cloud (opcional — só se usar hybrid/cloud_preferred) ---
# GROK_BIN=
# OPENAI_API_KEY=